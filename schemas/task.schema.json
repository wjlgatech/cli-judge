{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agenttool-bench.dev/schemas/task.schema.json",
  "title": "ATB Task",
  "type": "object",
  "required": [
    "id",
    "dimension",
    "title",
    "fixture",
    "call",
    "assert",
    "points"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^d[1-5]\\."
    },
    "dimension": {
      "enum": [
        "D1",
        "D2",
        "D3",
        "D4",
        "D5"
      ]
    },
    "title": {
      "type": "string"
    },
    "fixture": {
      "type": "string",
      "description": "relative path to the bound fixture"
    },
    "call": {
      "type": "object",
      "required": [
        "argv"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "object"
        },
        "stdin": {
          "type": "string"
        },
        "no_tty": {
          "type": "boolean"
        }
      }
    },
    "compare_call": {
      "type": "object",
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "assert": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind"
        ],
        "properties": {
          "kind": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "points": {
      "type": "integer",
      "minimum": 1
    },
    "provenance": {
      "type": "string"
    },
    "synthetic": {
      "type": "boolean",
      "default": false
    }
  },
  "additionalProperties": true
}